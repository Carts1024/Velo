{
  "name": "@carts1024/velo-wallets",
  "version": "0.1.0-alpha.3",
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/element.js"
  ],
  "exports": {
    "./config": {
      "types": "./dist/types/config.d.ts",
      "import": "./dist/config.js"
    },
    "./browser": {
      "types": "./dist/types/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./element": {
      "types": "./dist/types/element.d.ts",
      "import": "./dist/element.js"
    },
    "./react": {
      "types": "./dist/types/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && tsc --project tsconfig.build.json && vite build --config vite.cdn.config.ts",
    "lint:fix": "oxlint --fix . && oxfmt --write . && tsc --noEmit",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run test",
    "test": "vitest run"
  },
  "devDependencies": {
    "@creit-tech/stellar-wallets-kit": "npm:@jsr/creit-tech__stellar-wallets-kit@2.3.0",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "happy-dom": "^20.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.9.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
