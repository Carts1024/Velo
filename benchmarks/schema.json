{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Velo benchmark report",
  "type": "object",
  "required": ["status", "manifestVersion", "scenario", "scenarioVersion", "profile", "window", "mode", "runId", "revision", "capturedAt", "region", "runtime", "network", "dependencyVersions", "dependencyEndpoints", "payloadIdentity", "datasetIdentity", "workload", "attemptedSamples", "successfulSamples", "errorSamples", "throughput", "errorTaxonomy", "http503", "latencyMs"],
  "additionalProperties": false,
  "properties": {
    "status": { "enum": ["captured"] },
    "manifestVersion": { "type": "integer", "const": 2 },
    "scenario": { "type": "string" },
    "scenarioVersion": { "type": "integer", "minimum": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "capturedAt": { "type": "string", "format": "date-time" },
    "region": { "type": "string", "minLength": 1 },
    "runtime": { "type": "string", "minLength": 1 },
    "network": { "type": "string", "minLength": 1 },
    "dependencyVersions": { "type": "string", "minLength": 1 },
    "dependencyEndpoints": { "type": "string", "minLength": 1 },
    "payloadIdentity": { "type": "string", "minLength": 1 },
    "datasetIdentity": { "type": "string", "minLength": 1 },
    "profile": { "type": "string" },
    "window": { "type": "string" },
    "mode": { "enum": ["capture", "fixture"] },
    "workload": { "type": "object" },
    "attemptedSamples": { "type": "integer", "minimum": 1 },
    "successfulSamples": { "type": "integer", "minimum": 0 },
    "errorSamples": { "type": "integer", "minimum": 0 },
    "throughput": { "type": "object" },
    "errorTaxonomy": { "type": "object" },
    "http503": { "type": "object" },
    "latencyMs": { "type": "object" }
  }
}
