{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Velo Sprint 9 benchmark evidence report",
  "type": "object",
  "required": [
    "status",
    "manifestVersion",
    "evidenceSchemaVersion",
    "capturedAt",
    "cohortId",
    "revision",
    "baseline",
    "contributors",
    "sourceCaptures",
    "sampleArtifact",
    "runs"
  ],
  "additionalProperties": false,
  "$defs": {
    "percentiles": {
      "type": "object",
      "required": ["p50", "p95", "p99", "max", "count"],
      "properties": {
        "unit": { "const": "ms" },
        "p50": { "type": "number", "minimum": 0 },
        "p95": { "type": "number", "minimum": 0 },
        "p99": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "clockProvenance": {
      "type": "object",
      "required": ["id", "source", "kind", "unit", "synchronization", "resolutionMs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["monotonic", "wall"] },
        "unit": { "const": "ms" },
        "synchronization": { "type": "string", "minLength": 1, "not": { "const": "unknown" } },
        "resolutionMs": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "run": {
      "type": "object",
      "required": [
        "status",
        "evidenceMode",
        "manifestVersion",
        "evidenceSchemaVersion",
        "runId",
        "captureId",
        "cohortId",
        "scenario",
        "scenarioVersion",
        "adapter",
        "profile",
        "temperature",
        "window",
        "mode",
        "revision",
        "capturedAt",
        "region",
        "runtime",
        "network",
        "dependencyVersions",
        "dependencyEndpoints",
        "payloadIdentity",
        "datasetIdentity",
        "clockProvenance",
        "fixtureControl",
        "coldReset",
        "workload",
        "pacing",
        "saturation",
        "attemptedSamples",
        "successfulSamples",
        "errorSamples",
        "droppedSamples",
        "throughput",
        "errorTaxonomy",
        "http503",
        "latencyMs",
        "lifecycleMetrics"
      ],
      "properties": {
        "status": { "const": "captured" },
        "evidenceMode": { "const": "real" },
        "manifestVersion": { "const": 3 },
        "evidenceSchemaVersion": { "const": 2 },
        "runId": { "type": "string", "minLength": 1 },
        "captureId": { "type": "string", "minLength": 1 },
        "cohortId": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "scenarioVersion": { "type": "integer", "minimum": 1 },
        "adapter": { "enum": ["http", "control"] },
        "profile": { "enum": ["normal", "growth"] },
        "temperature": { "enum": ["cold", "warm"] },
        "window": { "enum": ["morning", "afternoon", "evening"] },
        "mode": { "const": "capture" },
        "clockProvenance": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clockProvenance" }
        },
        "fixtureControl": {
          "type": "object",
          "required": ["authorized", "cohortId", "setupReceiptId", "cleanup"]
        },
        "coldReset": {
          "type": "object",
          "required": ["required", "verifiedSamples", "methods"]
        },
        "latencyMs": { "$ref": "#/$defs/percentiles" },
        "lifecycleMetrics": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/percentiles" }
        }
      }
    }
  },
  "properties": {
    "status": { "const": "suite_completed" },
    "manifestVersion": { "const": 3 },
    "evidenceSchemaVersion": { "const": 2 },
    "capturedAt": { "type": "string", "format": "date-time" },
    "cohortId": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "baseline": {
      "type": "object",
      "required": ["id", "revision", "capturedAt", "artifact", "sha256", "scenarios"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifact": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "scenarios": { "type": "object", "minProperties": 7 }
      }
    },
    "contributors": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["rank", "name", "controlledBy", "impactMs", "sampleCount"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "controlledBy": { "const": "Velo" },
          "impactMs": { "type": "number", "minimum": 0 },
          "sampleCount": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "sourceCaptures": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "window",
          "captureId",
          "cohortId",
          "revision",
          "startedAt",
          "completedAt",
          "capturedAt",
          "reportSha256"
        ],
        "properties": {
          "window": { "enum": ["morning", "afternoon", "evening"] },
          "captureId": { "type": "string", "minLength": 1 },
          "cohortId": { "type": "string", "minLength": 1 },
          "revision": { "type": "string", "minLength": 1 },
          "startedAt": { "type": "string", "format": "date-time" },
          "completedAt": { "type": "string", "format": "date-time" },
          "capturedAt": { "type": "string", "format": "date-time" },
          "reportSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "sampleArtifact": {
      "type": "object",
      "required": ["format", "path", "sha256", "records"],
      "properties": {
        "format": { "const": "ndjson" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "records": { "type": "integer", "minimum": 84000 }
      }
    },
    "runs": { "type": "array", "minItems": 84, "maxItems": 84, "items": { "$ref": "#/$defs/run" } }
  }
}
