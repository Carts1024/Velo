{
  "name": "turbo-next-convex",
  "private": true,
  "scripts": {
    "benchmark:gate": "node scripts/benchmark-gate.mjs",
    "benchmark:gate:test": "node --test scripts/release-gate.test.mjs scripts/benchmark-sprint9.test.mjs scripts/telemetry-overhead-gate.test.mjs scripts/observability-assets.test.mjs",
    "benchmark:merge": "node scripts/benchmark-merge.mjs",
    "benchmark:report": "node scripts/benchmark-report.mjs",
    "benchmark:smoke": "node scripts/benchmark.mjs --dry-run --suite",
    "benchmark:test": "node --test scripts/benchmark.test.mjs scripts/benchmark-sprint9.test.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint:fix": "turbo run lint:fix",
    "prepare": "husky",
    "test": "turbo run test"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.8.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.25.0"
